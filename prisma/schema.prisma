generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id              String           @id @default(cuid())
  name            String
  documentId      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  users           User[]
  leads           Lead[]
  whatsappSession WhatsAppSession?
}

model User {
  id             String       @id @default(cuid())
  name           String
  email          String       @unique
  passwordHash   String
  role           String       @default("advogado") // admin | advogado | estagiario
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Lead {
  id             String    @id @default(cuid())
  name           String
  phone          String
  email          String?
  niche          String    // consumidor | trabalhista | previdenciario
  status         String    @default("novo") // novo | qualificando | qualificado | contrato_enviado | convertido | descartado
  score          Int       @default(0)
  aiSummary      String?
  lastMessage    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@index([organizationId, status])
  @@index([organizationId, createdAt(sort: Desc)])
}

model Message {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sender    String   // lead | ia | advogado
  content   String
  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
}

model WhatsAppSession {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  instanceName   String
  status         String       @default("disconnected") // disconnected | connecting | connected
  qrCode         String?
  updatedAt      DateTime     @updatedAt
}
